# Copy this file to .env and fill in your real values.
# Never commit the real .env file to GitHub — it's already in .gitignore.

# Get this from Supabase: Project Settings → Database → Connection string → URI
# Use the "Session" or "Direct connection" string — looks like:
# postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:Cm020%40122q.@db.lrboegiyuhbemfkmlbgq.supabase.co:5432/postgres

# Any long random string — used to sign login tokens
JWT_SECRET=

# Render/hosting sets this automatically — leave blank for local dev
PORT=5000
